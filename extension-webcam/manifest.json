{
  "manifest_version": 3,
  "name": "Meet getUserMedia Raw Data PoC",
  "version": "0.1.0",
  "description": "PoC extension that hooks getUserMedia on Google Meet and samples local video frames/audio data.",
  "permissions": ["activeTab", "downloads", "storage", "tabs", "unlimitedStorage"],
  "host_permissions": ["https://meet.google.com/*", "http://localhost:8787/*"],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Meet Raw Data PoC",
    "default_popup": "popup.html"
  }
}
